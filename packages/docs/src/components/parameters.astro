---
import type { Signature } from "@/lib/typedoc/schema";
import Parameter from "./parameter.astro";

type Props = {
  readonly parameters: Signature["parameters"];
  readonly class?: string;
};

const { parameters, class: class_ } = Astro.props;
---

<dl class:list={[class_]}>
  {parameters?.map((parameter) => <Parameter parameter={parameter} />)}
</dl>
