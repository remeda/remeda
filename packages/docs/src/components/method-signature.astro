---
import type { Signature } from "@/lib/typedoc/schema";
import { ChevronsUpDownIcon } from "lucide-react";
import FunctionReturnType from "./function-return-type.astro";
import Parameters from "./parameters.astro";

type Props = {
  readonly parameters: Signature["parameters"];
  readonly type: Signature["type"];
};

const { parameters, type } = Astro.props;
---

<details>
  <summary
    class="relative flex cursor-pointer list-none items-center [&::-webkit-details-marker]:hidden"
  >
    <slot />
    <ChevronsUpDownIcon
      className="absolute right-0 mr-2 size-4 text-background dark:text-foreground"
    />
  </summary>
  <div class="flex flex-col gap-3 p-2">
    <figure>
      <figcaption>Parameters</figcaption>
      <Parameters
        class="mt-1 grid grid-cols-[max-content_1fr] gap-x-2 gap-y-1 text-sm"
        parameters={parameters}
      />
    </figure>
    <figure>
      <figcaption>Returns</figcaption>
      <FunctionReturnType class="text-sm font-semibold" type={type} />
    </figure>
  </div>
</details>
