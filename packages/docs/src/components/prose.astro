---
import type { HTMLAttributes } from "astro/types";

type Tags = "article" | "div";

type Props = HTMLAttributes<Tags> & {
  readonly as?: Tags;
};

const { as: Tag = "div", class: class_, ...props } = Astro.props;
---

<Tag
  class:list={[
    "prose max-w-2xl prose-slate dark:prose-invert prose-code:text-primary prose-code:before:content-none prose-code:after:content-none",
    class_,
  ]}
  {...props}
>
  <slot />
</Tag>
