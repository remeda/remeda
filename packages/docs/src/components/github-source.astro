---
import { buttonVariants } from "@/components/ui/button";
import GitHubLogoIcon from "./github-logo-icon.astro";

type Props = {
  readonly url: string;
};

const { url } = Astro.props;
---

<a
  class:list={buttonVariants({ variant: "secondary", size: "sm" })}
  href={url}
  rel="noopener"
  target="_blank"
  title="View source on GitHub"
>
  <GitHubLogoIcon />
</a>
