---
import { format, type Options } from "prettier";
import ThemedCode from "./themed-code.astro";

const PRETTIER_OPTIONS = {
  parser: "typescript",
} as const satisfies Options;

type Props = {
  readonly class?: string;
  readonly code: string;
  readonly inline?: boolean;
};

const { code, class: class_, inline = false } = Astro.props;

const formattedCode = await format(code, {
  ...PRETTIER_OPTIONS,
  // For inline rendering, disable Prettier's line wrapping so the snippet stays
  // on one line.
  ...(inline && { printWidth: Number.POSITIVE_INFINITY }),
});
---

<ThemedCode
  class:list={["rounded-sm px-4 py-2", class_]}
  code={formattedCode.trimEnd()}
  inline={inline}
  lang="typescript"
  wrap
/>
