---
const VARIANTS = {
  accent:
    "https://www.netlify.com/assets/badges/netlify-badge-color-accent.svg",
  bg: "https://www.netlify.com/assets/badges/netlify-badge-color-bg.svg",
  light: "https://www.netlify.com/assets/badges/netlify-badge-light.svg",
  dark: "https://www.netlify.com/assets/badges/netlify-badge-dark.svg",
} as const;

type Props = {
  readonly variant?: keyof typeof VARIANTS;
};

const { variant = "accent" } = Astro.props;
---

<a href="https://www.netlify.com" rel="noopener noreferrer" target="_blank">
  <img alt="Deploys by Netlify" src={VARIANTS[variant]} />
</a>
